```

## 5.5 配置管理实现

### 5.5.1 配置管理器
```go
package config

import (
    "fmt"
    "os"
    "path/filepath"
    "strings"
    "time"
    
    "github.com/spf13/viper"
)

type Manager struct {
    config *Config
    viper  *viper.Viper
}

func NewManager() *Manager {
    return &Manager{
        viper: viper.New(),
    }
}

// Load 加载配置
func (m *Manager) Load(configPath string) error {
    // 设置配置文件路径
    if configPath != "" {
        m.viper.SetConfigFile(configPath)
    } else {
        m.viper.SetConfigName("config")
        m.viper.SetConfigType("yaml")
        m.viper.AddConfigPath("./configs")
        m.viper.AddConfigPath(".")
    }
    
    // 设置环境变量前缀
    m.viper.SetEnvPrefix("")
    m.viper.SetEnvKeyReplacer(strings.NewReplacer(".", "_"))
    m.viper.AutomaticEnv()
    
    // 读取配置文件
    if err := m.viper.ReadInConfig(); err != nil {
        if _, ok := err.(viper.ConfigFileNotFoundError); !ok {
            return fmt.Errorf("读取配置文件失败: %w", err)
        }
    }
    
    // 绑定环境变量
    m.bindEnvVars()
    
    // 解析配置
    config := &Config{}
    if err := m.viper.Unmarshal(config); err != nil {
        return fmt.Errorf("解析配置失败: %w", err)
    }
    
    // 验证配置
    if err := m.validateConfig(config); err != nil {
        return fmt.Errorf("配置验证失败: %w", err)
    }
    
    m.config = config
    return nil
}

// bindEnvVars 绑定环境变量
func (m *Manager) bindEnvVars() {
    // 应用配置
    m.viper.BindEnv("app.name", "APP_NAME")
    m.viper.BindEnv("app.version", "APP_VERSION")
    m.viper.BindEnv("app.env", "APP_ENV")
    m.viper.BindEnv("app.debug", "APP_DEBUG")
    
    // 数据库配置
    m.viper.BindEnv("database.type", "DB_TYPE")
    m.viper.BindEnv("database.host", "DB_HOST")
    m.viper.BindEnv("database.port", "DB_PORT")
    m.viper.BindEnv("database.user", "DB_USER")
    m.viper.BindEnv("database.password", "DB_PASSWORD")
    m.viper.BindEnv("database.database", "DB_NAME")
    m.viper.BindEnv("database.ssl_mode", "DB_SSL_MODE")
    
    // Redis配置
    m.viper.BindEnv("redis.host", "REDIS_HOST")
    m.viper.BindEnv("redis.port", "REDIS_PORT")
    m.viper.BindEnv("redis.password", "REDIS_PASSWORD")
    m.viper.BindEnv("redis.database", "REDIS_DATABASE")
    
    // 日志配置
    m.viper.BindEnv("log.level", "LOG_LEVEL")
    m.viper.BindEnv("log.format", "LOG_FORMAT")
    m.viper.BindEnv("log.output", "LOG_OUTPUT")
    
    // 服务器配置
    m.viper.BindEnv("server.host", "SERVER_HOST")
    m.viper.BindEnv("server.port", "SERVER_PORT")
    
    // 监控配置
    m.viper.BindEnv("monitor.prometheus.enabled", "PROMETHEUS_ENABLED")
    m.viper.BindEnv("monitor.pprof.enabled", "PPROF_ENABLED")
}

// validateConfig 验证配置
func (m *Manager) validateConfig(config *Config) error {
    // 验证应用配置
    if config.App.Name == "" {
        return fmt.Errorf("应用名称不能为空")
    }
    
    // 验证数据库配置
    if config.Database.Host == "" {
        return fmt.Errorf("数据库主机不能为空")
    }
    if config.Database.Port <= 0 {
        return fmt.Errorf("数据库端口必须大于0")
    }
    
    // 验证服务器配置
    if config.Server.Port <= 0 {
        return fmt.Errorf("服务器端口必须大于0")
    }
    
    return nil
}

// GetConfig 获取配置
func (m *Manager) GetConfig() *Config {
    return m.config
}

// WatchConfig 监听配置文件变化
func (m *Manager) WatchConfig(callback func(*Config)) {
    m.viper.WatchConfig()
    m.viper.OnConfigChange(func(e fsnotify.Event) {
        // 重新加载配置
        if err := m.Load(""); err != nil {
            log.Printf("重新加载配置失败: %v", err)
            return
        }
        
        // 调用回调函数
        if callback != nil {
            callback(m.config)
        }
    })
}
```

### 5.5.2 配置使用示例
```go
package main

import (
    "log"
    "os"
    
    "github.com/make-bin/server-tpl/pkg/config"
)

func main() {
    // 创建配置管理器
    configManager := config.NewManager()
    
    // 加载配置
    configPath := os.Getenv("CONFIG_PATH")
    if err := configManager.Load(configPath); err != nil {
        log.Fatalf("加载配置失败: %v", err)
    }
    
    // 获取配置
    cfg := configManager.GetConfig()
    
    // 监听配置变化
    configManager.WatchConfig(func(newConfig *config.Config) {
        log.Printf("配置已更新: %s", newConfig.App.Name)
        // 处理配置更新逻辑
    })
    
    // 使用配置启动服务
    startServer(cfg)
}

func startServer(cfg *config.Config) {
    // 使用配置启动服务器
    log.Printf("启动服务器: %s:%d", cfg.Server.Host, cfg.Server.Port)
}
```

## 5.6 配置最佳实践

### 5.6.1 配置分层
- **默认配置**: 提供合理的默认值
- **环境配置**: 根据环境调整配置
- **本地配置**: 开发人员本地配置
- **运行时配置**: 通过环境变量或命令行参数覆盖

### 5.6.2 安全考虑
- **敏感信息**: 使用环境变量存储密码、密钥等敏感信息
- **配置文件**: 不要将包含敏感信息的配置文件提交到版本控制
- **权限控制**: 确保配置文件有适当的文件权限
- **加密存储**: 考虑对敏感配置进行加密

### 5.6.3 配置验证
- **类型检查**: 验证配置值的类型和范围
- **依赖检查**: 检查配置项之间的依赖关系
- **格式验证**: 验证URL、路径等格式
- **完整性检查**: 确保必需的配置项存在

### 5.6.4 配置文档
- **配置说明**: 为每个配置项提供详细的说明
- **示例配置**: 提供完整的配置示例
- **环境说明**: 说明不同环境的配置差异
- **变更记录**: 记录配置变更历史

## 5.7 配置工具

### 5.7.1 配置生成工具
```go
// 生成配置模板
func GenerateConfigTemplate() error {
    config := &Config{
        App: AppConfig{
            Name:    "your-app-name",
            Version: "1.0.0",
            Env:     "development",
            Debug:   true,
        },
        Database: DatabaseConfig{
            Type:     "postgresql",
            Host:     "localhost",
            Port:     5432,
            User:     "postgres",
            Password: "password",
            Database: "your_database",
        },
        // ... 其他配置
    }
    
    // 写入配置文件
    return writeConfigToFile(config, "configs/config.template.yaml")
}
```

### 5.7.2 配置验证工具
```go
// 验证配置文件
func ValidateConfig(configPath string) error {
    configManager := NewManager()
    return configManager.Load(configPath)
}
```

### 5.7.3 配置迁移工具
```go
// 配置迁移
func MigrateConfig(oldConfigPath, newConfigPath string) error {
    // 读取旧配置
    oldConfig, err := loadOldConfig(oldConfigPath)
    if err != nil {
        return err
    }
    
    // 转换为新格式
    newConfig := convertToNewFormat(oldConfig)
    
    // 写入新配置
    return writeConfigToFile(newConfig, newConfigPath)
}
