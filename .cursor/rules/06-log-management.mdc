### 6.5.2 日志记录示例
```go
// HTTP请求日志
func logHTTPRequest(ctx context.Context, req *http.Request, statusCode int, duration time.Duration) {
    logger := GetLogger().WithContext(ctx).WithFields(logrus.Fields{
        FieldRequestID:    ctx.Value("request_id"),
        FieldMethod:       req.Method,
        FieldPath:         req.URL.Path,
        FieldIP:           getClientIP(req),
        FieldUserAgent:    req.UserAgent(),
        FieldStatusCode:   statusCode,
        FieldResponseTime: duration.Milliseconds(),
    })
    
    if statusCode >= 400 {
        logger.Error("HTTP请求失败")
    } else {
        logger.Info("HTTP请求完成")
    }
}

// 业务操作日志
func logBusinessOperation(ctx context.Context, operation, resource string, resourceID interface{}, err error) {
    fields := logrus.Fields{
        FieldOperation:  operation,
        FieldResource:   resource,
        FieldResourceID: resourceID,
    }
    
    if err != nil {
        fields[FieldError] = err.Error()
        fields[FieldErrorType] = getErrorType(err)
    }
    
    logger := GetLogger().WithContext(ctx).WithFields(fields)
    
    if err != nil {
        logger.Error("业务操作失败")
    } else {
        logger.Info("业务操作成功")
    }
}

// 数据库操作日志
func logDatabaseOperation(ctx context.Context, operation, table string, duration time.Duration, err error) {
    fields := logrus.Fields{
        FieldOperation: operation,
        FieldResource:  "database",
        "table":        table,
        "duration":     duration.Milliseconds(),
    }
    
    if err != nil {
        fields[FieldError] = err.Error()
    }
    
    logger := GetLogger().WithContext(ctx).WithFields(fields)
    
    if err != nil {
        logger.Error("数据库操作失败")
    } else {
        logger.Debug("数据库操作完成")
    }
}
```

## 6.6 日志中间件

### 6.6.1 HTTP日志中间件
```go
package middleware

import (
    "context"
    "net/http"
    "time"
    
    "github.com/gin-gonic/gin"
    "github.com/google/uuid"
    "github.com/make-bin/server-tpl/pkg/logger"
)

// Logger HTTP日志中间件
func Logger() gin.HandlerFunc {
    return func(c *gin.Context) {
        start := time.Now()
        
        // 生成请求ID
        requestID := uuid.New().String()
        ctx := context.WithValue(c.Request.Context(), "request_id", requestID)
        c.Request = c.Request.WithContext(ctx)
        
        // 设置请求ID到响应头
        c.Header("X-Request-ID", requestID)
        
        // 处理请求
        c.Next()
        
        // 记录请求日志
        duration := time.Since(start)
        statusCode := c.Writer.Status()
        
        logHTTPRequest(ctx, c.Request, statusCode, duration)
    }
}

// logHTTPRequest 记录HTTP请求日志
func logHTTPRequest(ctx context.Context, req *http.Request, statusCode int, duration time.Duration) {
    log := logger.GetLogger().WithContext(ctx).WithFields(logrus.Fields{
        "request_id":    ctx.Value("request_id"),
        "method":        req.Method,
        "path":          req.URL.Path,
        "query":         req.URL.RawQuery,
        "ip":            getClientIP(req),
        "user_agent":    req.UserAgent(),
        "status_code":   statusCode,
        "response_time": duration.Milliseconds(),
        "content_length": req.ContentLength,
    })
    
    switch {
    case statusCode >= 500:
        log.Error("HTTP请求服务器错误")
    case statusCode >= 400:
        log.Warn("HTTP请求客户端错误")
    default:
        log.Info("HTTP请求成功")
    }
}

// getClientIP 获取客户端IP
func getClientIP(req *http.Request) string {
    if ip := req.Header.Get("X-Forwarded-For"); ip != "" {
        return ip
    }
    if ip := req.Header.Get("X-Real-IP"); ip != "" {
        return ip
    }
    return req.RemoteAddr
}
```

### 6.6.2 错误日志中间件
```go
// ErrorLogger 错误日志中间件
func ErrorLogger() gin.HandlerFunc {
    return func(c *gin.Context) {
        c.Next()
        
        // 检查是否有错误
        if len(c.Errors) > 0 {
            for _, err := range c.Errors {
                log := logger.GetLogger().WithContext(c.Request.Context()).WithFields(logrus.Fields{
                    "request_id": c.Request.Context().Value("request_id"),
                    "error":      err.Error(),
                    "error_type": getErrorType(err.Err),
                })
                log.Error("请求处理错误")
            }
        }
    }
}
```

## 6.7 日志最佳实践

### 6.7.1 日志级别使用
- **TRACE**: 详细的调试信息，仅在开发环境使用
- **DEBUG**: 调试信息，用于问题排查
- **INFO**: 一般信息，记录重要的业务操作
- **WARN**: 警告信息，记录可能的问题
- **ERROR**: 错误信息，记录错误但不影响系统运行
- **FATAL**: 致命错误，记录后程序退出
- **PANIC**: 系统崩溃，记录后程序崩溃

### 6.7.2 日志内容规范
- **简洁明了**: 日志消息应该简洁明了
- **结构化**: 使用结构化字段而不是字符串拼接
- **上下文**: 包含足够的上下文信息
- **敏感信息**: 不要记录敏感信息（密码、令牌等）
- **性能考虑**: 避免在日志中执行昂贵的操作

### 6.7.3 日志性能优化
- **异步日志**: 使用异步日志避免阻塞主线程
- **缓冲写入**: 使用缓冲写入减少I/O操作
- **级别过滤**: 在生产环境中使用较高的日志级别
- **采样日志**: 对高频日志进行采样

### 6.7.4 日志管理
- **日志轮转**: 配置日志文件轮转避免磁盘空间不足
- **日志压缩**: 对旧日志进行压缩节省存储空间
- **日志清理**: 定期清理过期的日志文件
- **监控告警**: 监控日志文件大小和错误率

