# 6. 日志管理规范

## 6.1 概述

本规范定义了Go HTTP Server项目的日志管理标准，包括日志级别、格式规范、输出配置、结构化日志和最佳实践。

## 6.2 日志架构

### 6.2.1 日志级别
```
日志级别（从低到高）：
1. TRACE - 详细的调试信息
2. DEBUG - 调试信息
3. INFO - 一般信息
4. WARN - 警告信息
5. ERROR - 错误信息
6. FATAL - 致命错误
7. PANIC - 系统崩溃
```

### 6.2.2 日志组件
- **日志记录器**: 负责记录日志
- **日志格式化器**: 负责格式化日志输出
- **日志输出器**: 负责输出到不同目标
- **日志轮转**: 负责日志文件管理

## 6.3 日志配置

### 6.3.1 日志配置结构
```go
type LogConfig struct {
    Level      string `mapstructure:"level"`
    Format     string `mapstructure:"format"`      // json, text
    Output     string `mapstructure:"output"`      // stdout, file, both
    FilePath   string `mapstructure:"file_path"`
    MaxSize    int    `mapstructure:"max_size"`    // MB
    MaxBackups int    `mapstructure:"max_backups"`
    MaxAge     int    `mapstructure:"max_age"`     // days
    Compress   bool   `mapstructure:"compress"`
    
    // 结构化日志配置
    Fields map[string]interface{} `mapstructure:"fields"`
    
    // 性能配置
    BufferSize int `mapstructure:"buffer_size"`
    Async      bool `mapstructure:"async"`
}
```

### 6.3.2 配置文件示例
```yaml
# configs/config.yaml
log:
  level: "info"
  format: "json"
  output: "both"
  file_path: "logs/app.log"
  max_size: 100
  max_backups: 3
  max_age: 28
  compress: true
  fields:
    service: "go-http-server"
    version: "1.0.0"
    environment: "production"
  buffer_size: 1024
  async: true
```

## 6.4 日志实现

### 6.4.1 日志管理器
```go
package logger

import (
    "context"
    "fmt"
    "os"
    "path/filepath"
    "time"
    
    "github.com/sirupsen/logrus"
    "gopkg.in/natefinch/lumberjack.v2"
)

type Manager struct {
    logger *logrus.Logger
    config *LogConfig
}

func NewManager(config *LogConfig) (*Manager, error) {
    logger := logrus.New()
    
    // 设置日志级别
    level, err := logrus.ParseLevel(config.Level)
    if err != nil {
        return nil, fmt.Errorf("解析日志级别失败: %w", err)
    }
    logger.SetLevel(level)
    
    // 设置日志格式
    if err := setLogFormat(logger, config.Format); err != nil {
        return nil, err
    }
    
    // 设置日志输出
    if err := setLogOutput(logger, config); err != nil {
        return nil, err
    }
    
    // 设置默认字段
    if config.Fields != nil {
        logger.AddHook(&DefaultFieldsHook{fields: config.Fields})
    }
    
    // 设置异步日志
    if config.Async {
        logger.SetOutput(&AsyncWriter{
            writer: logger.Out,
            buffer: make(chan []byte, config.BufferSize),
        })
    }
    
    return &Manager{
        logger: logger,
        config: config,
    }, nil
}

// setLogFormat 设置日志格式
func setLogFormat(logger *logrus.Logger, format string) error {
    switch format {
    case "json":
        logger.SetFormatter(&logrus.JSONFormatter{
            TimestampFormat: time.RFC3339,
            FieldMap: logrus.FieldMap{
                logrus.FieldKeyTime:  "timestamp",
                logrus.FieldKeyLevel: "level",
                logrus.FieldKeyMsg:   "message",
                logrus.FieldKeyFunc:  "function",
                logrus.FieldKeyFile:  "file",
            },
        })
    case "text":
        logger.SetFormatter(&logrus.TextFormatter{
            TimestampFormat: time.RFC3339,
            FullTimestamp:   true,
            ForceColors:     true,
        })
    default:
        return fmt.Errorf("不支持的日志格式: %s", format)
    }
    return nil
}

// setLogOutput 设置日志输出
func setLogOutput(logger *logrus.Logger, config *LogConfig) error {
    var outputs []io.Writer
    
    // 添加标准输出
    if config.Output == "stdout" || config.Output == "both" {
        outputs = append(outputs, os.Stdout)
    }
    
    // 添加文件输出
    if config.Output == "file" || config.Output == "both" {
        if err := os.MkdirAll(filepath.Dir(config.FilePath), 0755); err != nil {
            return fmt.Errorf("创建日志目录失败: %w", err)
        }
        
        fileWriter := &lumberjack.Logger{
            Filename:   config.FilePath,
            MaxSize:    config.MaxSize,
            MaxBackups: config.MaxBackups,
            MaxAge:     config.MaxAge,
            Compress:   config.Compress,
        }
        outputs = append(outputs, fileWriter)
    }
    
    if len(outputs) == 0 {
        return fmt.Errorf("未配置有效的日志输出")
    }
    
    if len(outputs) == 1 {
        logger.SetOutput(outputs[0])
    } else {
        logger.SetOutput(io.MultiWriter(outputs...))
    }
    
    return nil
}

// GetLogger 获取日志记录器
func (m *Manager) GetLogger() *logrus.Logger {
    return m.logger
}

// WithContext 创建带上下文的日志记录器
func (m *Manager) WithContext(ctx context.Context) *logrus.Entry {
    return m.logger.WithContext(ctx)
}

// WithFields 创建带字段的日志记录器
func (m *Manager) WithFields(fields logrus.Fields) *logrus.Entry {
    return m.logger.WithFields(fields)
}
```

### 6.4.2 默认字段钩子
```go
// DefaultFieldsHook 默认字段钩子
type DefaultFieldsHook struct {
    fields logrus.Fields
}

func (h *DefaultFieldsHook) Levels() []logrus.Level {
    return logrus.AllLevels
}

func (h *DefaultFieldsHook) Fire(entry *logrus.Entry) error {
    for key, value := range h.fields {
        entry.Data[key] = value
    }
    return nil
}
```

### 6.4.3 异步日志写入器
```go
// AsyncWriter 异步日志写入器
type AsyncWriter struct {
    writer io.Writer
    buffer chan []byte
}

func (w *AsyncWriter) Write(p []byte) (n int, err error) {
    // 复制数据以避免竞态条件
    data := make([]byte, len(p))
    copy(data, p)
    
    select {
    case w.buffer <- data:
        return len(p), nil
    default:
        // 缓冲区满，丢弃日志
        return len(p), nil
    }
}

func (w *AsyncWriter) start() {
    go func() {
        for data := range w.buffer {
            w.writer.Write(data)
        }
    }()
}
```

