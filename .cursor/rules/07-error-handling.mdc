## 7.4 错误处理实现

### 7.4.1 错误包装器
```go
package errors

import (
    "fmt"
    "runtime"
    "strings"
    
    "github.com/make-bin/server-tpl/pkg/bcode"
)

// ErrorWrapper 错误包装器
type ErrorWrapper struct {
    err        error
    code       int
    message    string
    details    string
    fields     map[string]interface{}
    stackTrace string
}

// Wrap 包装错误
func Wrap(err error, code int, message string) error {
    return &ErrorWrapper{
        err:        err,
        code:       code,
        message:    message,
        stackTrace: getStackTrace(),
    }
}

// WrapWithDetails 包装错误并添加详细信息
func WrapWithDetails(err error, code int, message, details string) error {
    return &ErrorWrapper{
        err:        err,
        code:       code,
        message:    message,
        details:    details,
        stackTrace: getStackTrace(),
    }
}

// WrapWithFields 包装错误并添加字段
func WrapWithFields(err error, code int, message string, fields map[string]interface{}) error {
    return &ErrorWrapper{
        err:        err,
        code:       code,
        message:    message,
        fields:     fields,
        stackTrace: getStackTrace(),
    }
}

func (e *ErrorWrapper) Error() string {
    if e.err != nil {
        return fmt.Sprintf("%s: %v", e.message, e.err)
    }
    return e.message
}

func (e *ErrorWrapper) Unwrap() error {
    return e.err
}

func (e *ErrorWrapper) Code() int {
    return e.code
}

func (e *ErrorWrapper) Message() string {
    return e.message
}

func (e *ErrorWrapper) Details() string {
    return e.details
}

func (e *ErrorWrapper) Fields() map[string]interface{} {
    return e.fields
}

func (e *ErrorWrapper) StackTrace() string {
    return e.stackTrace
}

// getStackTrace 获取堆栈跟踪
func getStackTrace() string {
    const depth = 32
    var pcs [depth]uintptr
    n := runtime.Callers(3, pcs[:])
    frames := runtime.CallersFrames(pcs[:n])
    
    var stack strings.Builder
    for {
        frame, more := frames.Next()
        stack.WriteString(fmt.Sprintf("%s\n\t%s:%d\n", frame.Function, frame.File, frame.Line))
        if !more {
            break
        }
    }
    return stack.String()
}
```

### 7.4.2 错误处理器
```go
package handler

import (
    "net/http"
    "runtime/debug"
    
    "github.com/gin-gonic/gin"
    "github.com/make-bin/server-tpl/pkg/bcode"
    "github.com/make-bin/server-tpl/pkg/errors"
    "github.com/make-bin/server-tpl/pkg/logger"
)

// ErrorHandler 错误处理器
type ErrorHandler struct {
    logger logger.Logger
}

// NewErrorHandler 创建错误处理器
func NewErrorHandler(logger logger.Logger) *ErrorHandler {
    return &ErrorHandler{
        logger: logger,
    }
}

// Handle 处理错误
func (h *ErrorHandler) Handle(c *gin.Context, err error) {
    // 获取请求ID
    requestID := c.GetString("request_id")
    
    // 根据错误类型处理
    switch e := err.(type) {
    case *bcode.Error:
        h.handleBusinessError(c, e, requestID)
    case *errors.ErrorWrapper:
        h.handleWrappedError(c, e, requestID)
    default:
        h.handleGenericError(c, err, requestID)
    }
}

// handleBusinessError 处理业务错误
func (h *ErrorHandler) handleBusinessError(c *gin.Context, err *bcode.Error, requestID string) {
    // 设置请求ID
    err.RequestID = requestID
    
    // 记录错误日志
    h.logger.WithFields(logrus.Fields{
        "request_id": requestID,
        "error_code": err.Code,
        "error":      err.Message,
        "details":    err.Details,
    }).Error("业务错误")
    
    // 返回错误响应
    statusCode := h.getHTTPStatusCode(err.Code)
    c.JSON(statusCode, err)
}

// handleWrappedError 处理包装错误
func (h *ErrorHandler) handleWrappedError(c *gin.Context, err *errors.ErrorWrapper, requestID string) {
    // 创建业务错误
    businessError := bcode.NewErrorWithDetails(err.Code(), err.Message(), err.Details())
    businessError.RequestID = requestID
    businessError.Fields = err.Fields()
    businessError.StackTrace = err.StackTrace()
    
    // 记录错误日志
    h.logger.WithFields(logrus.Fields{
        "request_id":  requestID,
        "error_code":  err.Code(),
        "error":       err.Message(),
        "details":     err.Details(),
        "stack_trace": err.StackTrace(),
    }).Error("包装错误")
    
    // 返回错误响应
    statusCode := h.getHTTPStatusCode(err.Code())
    c.JSON(statusCode, businessError)
}

// handleGenericError 处理通用错误
func (h *ErrorHandler) handleGenericError(c *gin.Context, err error, requestID string) {
    // 创建业务错误
    businessError := bcode.NewErrorWithDetails(
        bcode.InternalServerError,
        "服务器内部错误",
        err.Error(),
    )
    businessError.RequestID = requestID
    
    // 记录错误日志
    h.logger.WithFields(logrus.Fields{
        "request_id": requestID,
        "error":      err.Error(),
    }).Error("通用错误")
    
    // 返回错误响应
    c.JSON(http.StatusInternalServerError, businessError)
}

// getHTTPStatusCode 获取HTTP状态码
func (h *ErrorHandler) getHTTPStatusCode(errorCode int) int {
    switch {
    case errorCode >= 1000 && errorCode < 2000:
        return http.StatusBadRequest
    case errorCode >= 2000 && errorCode < 3000:
        return http.StatusInternalServerError
    case errorCode >= 3000 && errorCode < 4000:
        return http.StatusBadRequest
    case errorCode >= 4000 && errorCode < 5000:
        return http.StatusBadRequest
    case errorCode >= 5000 && errorCode < 6000:
        return http.StatusNotFound
    default:
        return http.StatusInternalServerError
    }
}
```

### 7.4.3 错误中间件
```go
package middleware

import (
    "net/http"
    
    "github.com/gin-gonic/gin"
    "github.com/make-bin/server-tpl/pkg/handler"
    "github.com/make-bin/server-tpl/pkg/logger"
)

// ErrorMiddleware 错误处理中间件
func ErrorMiddleware(logger logger.Logger) gin.HandlerFunc {
    errorHandler := handler.NewErrorHandler(logger)
    
    return func(c *gin.Context) {
        // 处理panic
        defer func() {
            if err := recover(); err != nil {
                // 记录panic日志
                logger.WithFields(logrus.Fields{
                    "request_id": c.GetString("request_id"),
                    "panic":      err,
                }).Error("发生panic")
                
                // 返回500错误
                c.JSON(http.StatusInternalServerError, gin.H{
                    "code":      bcode.InternalServerError,
                    "message":   "服务器内部错误",
                    "request_id": c.GetString("request_id"),
                })
                c.Abort()
            }
        }()
        
        c.Next()
        
        // 处理错误
        if len(c.Errors) > 0 {
            for _, ginErr := range c.Errors {
                errorHandler.Handle(c, ginErr.Err)
            }
        }
    }
}
```

## 7.5 错误处理策略

### 7.5.1 分层错误处理
```go
// 数据层错误处理
func (r *userRepository) GetByID(ctx context.Context, id string) (*User, error) {
    user := &User{}
    if err := r.db.WithContext(ctx).Where("id = ?", id).First(user).Error; err != nil {
        if errors.Is(err, gorm.ErrRecordNotFound) {
            return nil, errors.WrapWithDetails(err, bcode.UserNotFound, "用户不存在", fmt.Sprintf("用户ID: %s", id))
        }
        return nil, errors.Wrap(err, bcode.DatabaseError, "数据库查询失败")
    }
    return user, nil
}

// 服务层错误处理
func (s *userService) GetUser(ctx context.Context, id string) (*User, error) {
    user, err := s.userRepo.GetByID(ctx, id)
    if err != nil {
        // 记录错误日志
        s.logger.WithContext(ctx).WithFields(logrus.Fields{
            "user_id": id,
            "error":   err.Error(),
        }).Error("获取用户失败")
        return nil, err
    }
    return user, nil
}

// 控制器层错误处理
func (c *UserController) GetUser(ctx *gin.Context) {
    id := ctx.Param("id")
    
    user, err := c.userService.GetUser(ctx, id)
    if err != nil {
        // 错误会被中间件处理
        ctx.Error(err)
        return
    }
    
    ctx.JSON(http.StatusOK, user)
}
```

### 7.5.2 错误恢复策略
```go
// 重试机制
func (s *userService) GetUserWithRetry(ctx context.Context, id string) (*User, error) {
    var user *User
    var err error
    
    for i := 0; i < 3; i++ {
        user, err = s.userRepo.GetByID(ctx, id)
        if err == nil {
            return user, nil
        }
        
        // 检查是否是可重试的错误
        if !isRetryableError(err) {
            return nil, err
        }
        
        // 等待后重试
        time.Sleep(time.Duration(i+1) * time.Second)
    }
    
    return nil, err
}

// 熔断器
type CircuitBreaker struct {
    failures  int
    threshold int
    timeout   time.Duration
    lastError time.Time
    state     string // closed, open, half-open
}

func (cb *CircuitBreaker) Execute(fn func() error) error {
    switch cb.state {
    case "open":
        if time.Since(cb.lastError) > cb.timeout {
            cb.state = "half-open"
        } else {
            return errors.New("熔断器开启")
        }
    }
    
    err := fn()
    if err != nil {
        cb.failures++
        cb.lastError = time.Now()
        
        if cb.failures >= cb.threshold {
            cb.state = "open"
        }
        return err
    }
    
    cb.failures = 0
    cb.state = "closed"
    return nil
}
```

## 7.6 错误监控和分析

### 7.6.1 错误监控
```go
// ErrorMonitor 错误监控器
type ErrorMonitor struct {
    errorCounts map[int]int64
    mu          sync.RWMutex
}

func (em *ErrorMonitor) RecordError(code int) {
    em.mu.Lock()
    defer em.mu.Unlock()
    
    em.errorCounts[code]++
}

func (em *ErrorMonitor) GetErrorStats() map[int]int64 {
    em.mu.RLock()
    defer em.mu.RUnlock()
    
    stats := make(map[int]int64)
    for code, count := range em.errorCounts {
        stats[code] = count
    }
    return stats
}

// 与Prometheus集成
func registerErrorMetrics() {
    errorCounter := prometheus.NewCounterVec(prometheus.CounterOpts{
        Name: "errors_total",
        Help: "Total number of errors by code",
    }, []string{"error_code", "error_type"})
    
    prometheus.MustRegister(errorCounter)
}
```

### 7.6.2 错误分析
```go
// ErrorAnalyzer 错误分析器
type ErrorAnalyzer struct {
    errors []ErrorRecord
    mu     sync.RWMutex
}

type ErrorRecord struct {
    Code       int       `json:"code"`
    Message    string    `json:"message"`
    Timestamp  time.Time `json:"timestamp"`
    RequestID  string    `json:"request_id"`
    StackTrace string    `json:"stack_trace"`
}

func (ea *ErrorAnalyzer) AddError(err *bcode.Error) {
    ea.mu.Lock()
    defer ea.mu.Unlock()
    
    record := ErrorRecord{
        Code:       err.Code,
        Message:    err.Message,
        Timestamp:  time.Now(),
        RequestID:  err.RequestID,
        StackTrace: err.StackTrace,
    }
    
    ea.errors = append(ea.errors, record)
}

func (ea *ErrorAnalyzer) GetErrorTrends() map[int]ErrorTrend {
    ea.mu.RLock()
    defer ea.mu.RUnlock()
    
    trends := make(map[int]ErrorTrend)
    for _, record := range ea.errors {
        trend := trends[record.Code]
        trend.Count++
        trend.LastOccurred = record.Timestamp
        trends[record.Code] = trend
    }
    
    return trends
}

type ErrorTrend struct {
    Count         int       `json:"count"`
    LastOccurred  time.Time `json:"last_occurred"`
    Frequency     float64   `json:"frequency"`
}
```

## 7.7 错误处理最佳实践

### 7.7.1 错误设计原则
- **明确性**: 错误消息应该明确说明问题
- **可操作性**: 错误应该提供解决建议
- **一致性**: 错误格式和结构应该一致
- **安全性**: 不要暴露敏感信息
- **可追踪性**: 包含足够的上下文信息

### 7.7.2 错误处理模式
- **快速失败**: 遇到错误立即返回
- **优雅降级**: 在部分功能失败时继续提供服务
- **重试机制**: 对临时错误进行重试
- **熔断器**: 防止错误传播
- **超时控制**: 设置合理的超时时间

### 7.7.3 错误日志记录
- **结构化日志**: 使用结构化字段记录错误
- **上下文信息**: 包含请求ID、用户ID等上下文
- **堆栈跟踪**: 记录完整的堆栈信息
- **错误分类**: 按错误类型进行分类
- **性能考虑**: 避免在错误处理中执行昂贵操作

### 7.7.4 错误响应规范
- **统一格式**: 使用统一的错误响应格式
- **状态码映射**: 正确映射HTTP状态码
- **国际化支持**: 支持多语言错误消息
- **版本兼容**: 保持错误响应格式的向后兼容
- **文档化**: 提供完整的错误码文档
