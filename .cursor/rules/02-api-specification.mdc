## 2.5 国际化与本地化（i18n/L10n）

### 2.5.1 目标
- 为 API 返回提供多语言消息（成功/错误），支持通过请求选择语言。

### 2.5.2 目录结构
```
pkg/utils/i18n/
└── i18n.go        # i18n 基础实现：Bundle、配置、上下文工具
```

### 2.5.3 语言解析策略
- 优先级：query 参数 `lang` -> 头 `X-Lang` -> 头 `Accept-Language` -> 默认语言
- 默认语言：`en`
- 默认支持：`en`, `zh-CN`

### 2.5.4 使用方式
```go
// 路由中启用中间件
engine.Use(middleware.I18n())

// 在响应辅助中自动本地化
middleware.SuccessResponse(c, data)        // message: success/成功
middleware.CreatedResponse(c, data)        // message: created/创建成功
middleware.ErrorResponse(c, err)           // message: 根据错误码映射到 error.xxx
```

### 2.5.5 API 返回规范（带 i18n）
- 统一成功响应：
```json
{
  "code": 200,
  "message": "success",  // 或 "成功"
  "data": { ... },
  "locale": "en"          // 实际解析的语言
}
```

- 统一错误响应：
```json
{
  "code": 404,
  "message": "Not found", // 或 "未找到"
  "details": "...",       // 可选
  "data": null,            // 可选
  "locale": "zh-CN"
}
```

### 2.5.6 文本与键
- 公共键：`common.success`, `common.created`, `service.running`
- 错误键：`error.400`, `error.401`, `error.403`, `error.404`, `error.409`, `error.422`, `error.500`
- 自定义业务错误可映射到上述通用键或新增键。

### 2.5.7 扩展语言
```go
bundle := i18n.Default()
bundle.AddMessages("ja", map[string]string{
    "common.success": "成功",
})
```

### 2.5.8 i18n 中间件实现
```go
package middleware

import (
    "net/http"
    "strings"
    
    "github.com/gin-gonic/gin"
    "github.com/make-bin/server-tpl/pkg/utils/i18n"
)

// I18n 国际化中间件
func I18n() gin.HandlerFunc {
    return func(c *gin.Context) {
        // 1. 从 query 参数获取语言
        lang := c.Query("lang")
        
        // 2. 从请求头获取语言
        if lang == "" {
            lang = c.GetHeader("X-Lang")
        }
        
        // 3. 从 Accept-Language 头获取语言
        if lang == "" {
            acceptLang := c.GetHeader("Accept-Language")
            if acceptLang != "" {
                // 解析 Accept-Language 头，获取第一个支持的语言
                langs := strings.Split(acceptLang, ",")
                for _, l := range langs {
                    l = strings.TrimSpace(strings.Split(l, ";")[0])
                    if l == "zh-CN" || l == "zh" {
                        lang = "zh-CN"
                        break
                    } else if l == "en" || l == "en-US" {
                        lang = "en"
                        break
                    }
                }
            }
        }
        
        // 4. 使用默认语言
        if lang == "" {
            lang = "en"
        }
        
        // 5. 验证语言是否支持
        if !isSupportedLanguage(lang) {
            lang = "en"
        }
        
        // 6. 设置语言到上下文
        c.Set("locale", lang)
        
        c.Next()
    }
}

// isSupportedLanguage 检查语言是否支持
func isSupportedLanguage(lang string) bool {
    supported := []string{"en", "zh-CN"}
    for _, l := range supported {
        if l == lang {
            return true
        }
    }
    return false
}

// SuccessResponse 成功响应（带国际化）
func SuccessResponse(c *gin.Context, data interface{}) {
    locale := c.GetString("locale")
    if locale == "" {
        locale = "en"
    }
    
    message := i18n.GetMessage(locale, "common.success")
    
    c.JSON(http.StatusOK, gin.H{
        "code":      200,
        "message":   message,
        "data":      data,
        "locale":    locale,
        "timestamp": time.Now().Format(time.RFC3339),
    })
}

// CreatedResponse 创建成功响应（带国际化）
func CreatedResponse(c *gin.Context, data interface{}) {
    locale := c.GetString("locale")
    if locale == "" {
        locale = "en"
    }
    
    message := i18n.GetMessage(locale, "common.created")
    
    c.JSON(http.StatusCreated, gin.H{
        "code":      201,
        "message":   message,
        "data":      data,
        "locale":    locale,
        "timestamp": time.Now().Format(time.RFC3339),
    })
}

// ErrorResponse 错误响应（带国际化）
func ErrorResponse(c *gin.Context, statusCode int, messageKey string, err error) {
    locale := c.GetString("locale")
    if locale == "" {
        locale = "en"
    }
    
    message := i18n.GetMessage(locale, messageKey)
    if message == "" {
        message = messageKey
    }
    
    response := gin.H{
        "code":      statusCode,
        "message":   message,
        "locale":    locale,
        "timestamp": time.Now().Format(time.RFC3339),
    }
    
    if err != nil {
        response["details"] = err.Error()
    }
    
    c.JSON(statusCode, response)
}
```

## 2.6 Gin 框架使用规范

### 2.6.1 路由定义
```go
package api

import (
    "github.com/gin-gonic/gin"
    "github.com/make-bin/server-tpl/pkg/api/middleware"
)

func RegisterRoutes(rg *gin.RouterGroup) {
    // 用户相关路由
    users := rg.Group("/users")
    {
        users.GET("", middleware.Auth(), GetUserList)
        users.POST("", middleware.Auth(), CreateUser)
        users.GET("/:id", middleware.Auth(), GetUser)
        users.PUT("/:id", middleware.Auth(), UpdateUser)
        users.DELETE("/:id", middleware.Auth(), DeleteUser)
        
        // 嵌套资源
        users.GET("/:id/orders", middleware.Auth(), GetUserOrders)
    }
    
    // 应用相关路由
    apps := rg.Group("/applications")
    {
        apps.GET("", middleware.Auth(), GetApplicationList)
        apps.POST("", middleware.Auth(), CreateApplication)
        apps.GET("/:id", middleware.Auth(), GetApplication)
        apps.PUT("/:id", middleware.Auth(), UpdateApplication)
        apps.DELETE("/:id", middleware.Auth(), DeleteApplication)
    }
}
```

### 2.6.2 控制器实现
```go
package api

import (
    "net/http"
    "strconv"
    
    "github.com/gin-gonic/gin"
    "github.com/make-bin/server-tpl/pkg/api/dto/v1"
    "github.com/make-bin/server-tpl/pkg/api/middleware"
    "github.com/make-bin/server-tpl/pkg/domain/service"
)

type UserController struct {
    userService service.UserService
}

func NewUserController(userService service.UserService) *UserController {
    return &UserController{
        userService: userService,
    }
}

// GetUserList godoc
// @Summary 获取用户列表
// @Description 分页获取用户列表
// @Tags users
// @Accept json
// @Produce json
// @Param page query int false "页码" default(1)
// @Param size query int false "每页数量" default(10)
// @Param name query string false "用户名模糊搜索"
// @Param email query string false "邮箱精确搜索"
// @Success 200 {object} middleware.Response{data=dto.UserListResponse}
// @Failure 400 {object} middleware.ErrorResponse
// @Failure 401 {object} middleware.ErrorResponse
// @Router /api/v1/users [get]
func (c *UserController) GetUserList(ctx *gin.Context) {
    // 1. 参数绑定和验证
    var req dto.GetUserListRequest
    if err := ctx.ShouldBindQuery(&req); err != nil {
        middleware.ErrorResponse(ctx, http.StatusBadRequest, "参数绑定失败", err)
        return
    }
    
    // 2. 业务逻辑处理
    users, total, err := c.userService.GetUserList(ctx, req)
    if err != nil {
        middleware.ErrorResponse(ctx, http.StatusInternalServerError, "获取用户列表失败", err)
        return
    }
    
    // 3. 响应数据组装
    response := dto.UserListResponse{
        Items: users,
        Pagination: dto.Pagination{
            Page:  req.Page,
            Size:  req.Size,
            Total: total,
            Pages: (total + req.Size - 1) / req.Size,
        },
    }
    
    middleware.SuccessResponse(ctx, response)
}

// CreateUser godoc
// @Summary 创建用户
// @Description 创建新用户
// @Tags users
// @Accept json
// @Produce json
// @Param user body dto.CreateUserRequest true "用户信息"
// @Success 201 {object} middleware.Response{data=dto.UserResponse}
// @Failure 400 {object} middleware.ErrorResponse
// @Failure 409 {object} middleware.ErrorResponse
// @Router /api/v1/users [post]
func (c *UserController) CreateUser(ctx *gin.Context) {
    // 1. 参数绑定和验证
    var req dto.CreateUserRequest
    if err := ctx.ShouldBindJSON(&req); err != nil {
        middleware.ErrorResponse(ctx, http.StatusBadRequest, "参数绑定失败", err)
        return
    }
    
    // 2. 业务逻辑处理
    user, err := c.userService.CreateUser(ctx, req)
    if err != nil {
        if err == service.ErrUserAlreadyExists {
            middleware.ErrorResponse(ctx, http.StatusConflict, "用户已存在", err)
            return
        }
        middleware.ErrorResponse(ctx, http.StatusInternalServerError, "创建用户失败", err)
        return
    }
    
    // 3. 响应
    middleware.CreatedResponse(ctx, user)
}
```

