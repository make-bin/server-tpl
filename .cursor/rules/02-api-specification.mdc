// UpdateUserRequest 更新用户请求
type UpdateUserRequest struct {
    Name   *string `json:"name,omitempty" binding:"omitempty,min=2,max=50" validate:"omitempty,min=2,max=50"`
    Email  *string `json:"email,omitempty" binding:"omitempty,email" validate:"omitempty,email"`
    Age    *int    `json:"age,omitempty" binding:"omitempty,gte=0,lte=150" validate:"omitempty,gte=0,lte=150"`
    Gender *string `json:"gender,omitempty" binding:"omitempty,oneof=male female other" validate:"omitempty,oneof=male female other"`
}

// GetUserListRequest 获取用户列表请求
type GetUserListRequest struct {
    Page  int    `form:"page" binding:"omitempty,min=1" validate:"omitempty,min=1"`
    Size  int    `form:"size" binding:"omitempty,min=1,max=100" validate:"omitempty,min=1,max=100"`
    Name  string `form:"name" binding:"omitempty,max=50" validate:"omitempty,max=50"`
    Email string `form:"email" binding:"omitempty,email" validate:"omitempty,email"`
}

// UserResponse 用户响应
type UserResponse struct {
    ID         int64     `json:"id"`
    Name       string    `json:"name"`
    Email      string    `json:"email"`
    Age        int       `json:"age"`
    Gender     string    `json:"gender"`
    CreateTime time.Time `json:"create_time"`
    UpdateTime time.Time `json:"update_time"`
}

// UserListResponse 用户列表响应
type UserListResponse struct {
    Items      []UserResponse `json:"items"`
    Pagination Pagination     `json:"pagination"`
}

// Pagination 分页信息
type Pagination struct {
    Page  int   `json:"page"`
    Size  int   `json:"size"`
    Total int64 `json:"total"`
    Pages int   `json:"pages"`
}
