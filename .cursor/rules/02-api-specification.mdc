## 2.9 中间件规范

### 2.9.1 认证中间件
```go
package middleware

import (
    "net/http"
    "strings"
    
    "github.com/gin-gonic/gin"
    "github.com/golang-jwt/jwt/v4"
)

// Auth 认证中间件
func Auth() gin.HandlerFunc {
    return func(c *gin.Context) {
        // 获取 Authorization 头
        authHeader := c.GetHeader("Authorization")
        if authHeader == "" {
            ErrorResponse(c, http.StatusUnauthorized, "缺少认证信息", nil)
            c.Abort()
            return
        }
        
        // 检查 Bearer token
        parts := strings.SplitN(authHeader, " ", 2)
        if !(len(parts) == 2 && parts[0] == "Bearer") {
            ErrorResponse(c, http.StatusUnauthorized, "认证格式错误", nil)
            c.Abort()
            return
        }
        
        tokenString := parts[1]
        
        // 验证 token
        claims, err := validateToken(tokenString)
        if err != nil {
            ErrorResponse(c, http.StatusUnauthorized, "token无效", err)
            c.Abort()
            return
        }
        
        // 将用户信息存储到上下文
        c.Set("user_id", claims.UserID)
        c.Set("username", claims.Username)
        
        c.Next()
    }
}

// Claims JWT 声明
type Claims struct {
    UserID   int64  `json:"user_id"`
    Username string `json:"username"`
    jwt.RegisteredClaims
}
```

### 2.9.2 CORS 中间件
