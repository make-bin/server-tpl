### 2.7.2 自定义验证器
```go
package api

import (
    "regexp"
    "unicode"
    
    "github.com/go-playground/validator/v10"
)

// RegisterCustomValidators 注册自定义验证器
func RegisterCustomValidators(v *validator.Validate) {
    // 用户名验证器：必须以小写字母开头，只能包含小写字母、数字、连字符
    v.RegisterValidation("username", func(fl validator.FieldLevel) bool {
        username, ok := fl.Field().Interface().(string)
        if !ok {
            return false
        }
        
        if len(username) < 3 || len(username) > 20 {
            return false
        }
        
        // 必须以小写字母开头
        if !unicode.IsLower([]rune(username)[0]) {
            return false
        }
        
        // 只能包含小写字母、数字、连字符
        matched, _ := regexp.MatchString("^[a-z][a-z0-9-]*[a-z0-9]$", username)
        return matched
    })
    
    // 版本号验证器：不能包含中文字符
    v.RegisterValidation("version", func(fl validator.FieldLevel) bool {
        version, ok := fl.Field().Interface().(string)
        if !ok {
            return false
        }
        
        // 检查是否包含中文字符
        matched, _ := regexp.MatchString("^[^\u4e00-\u9fa5]+$", version)
        return matched
    })
    
    // 手机号验证器
    v.RegisterValidation("phone", func(fl validator.FieldLevel) bool {
        phone, ok := fl.Field().Interface().(string)
        if !ok {
            return false
        }
        
        matched, _ := regexp.MatchString("^1[3-9]\\d{9}$", phone)
        return matched
    })
}
```

