## 2.10 错误处理规范

### 2.10.1 错误码定义
```go
package bcode

// 业务错误码定义
const (
    // 通用错误码 (1000-1999)
    Success           = 200
    BadRequest        = 400
    Unauthorized      = 401
    Forbidden         = 403
    NotFound          = 404
    Conflict          = 409
    UnprocessableEntity = 422
    InternalError     = 500
    
    // 用户相关错误码 (2000-2999)
    UserNotFound      = 2001
    UserAlreadyExists = 2002
    InvalidPassword   = 2003
    UserDisabled      = 2004
    
    // 应用相关错误码 (3000-3999)
    AppNotFound       = 3001
    AppAlreadyExists  = 3002
    AppDisabled       = 3003
)

// Error 业务错误
type Error struct {
    Code    int    `json:"code"`
    Message string `json:"message"`
}

func (e *Error) Error() string {
    return e.Message
}

// NewError 创建新的业务错误
func NewError(code int, message string) *Error {
    return &Error{
        Code:    code,
        Message: message,
    }
}
